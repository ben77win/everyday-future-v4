---
import Calendly from './Calendly.astro';
import { practiceOptions, optionByKey } from '../data/options';

const calendlyUrlsJson = JSON.stringify(
  Object.fromEntries(practiceOptions.map((o) => [o.key, o.calendlyUrl]))
);
const optionLabelsJson = JSON.stringify(
  Object.fromEntries(practiceOptions.map((o) => [o.key, o.label]))
);
---

<div id="bfData" data-labels={optionLabelsJson} data-urls={calendlyUrlsJson} hidden></div>

<div class="begin-flow" id="beginFlow">

  <!-- ── STEP 1: Option selection ─────────────────────────────── -->
  <div class="bf-step" id="bfStep1">
    <div class="bf-step__inner">

      <div class="bf-header">
        <h1 class="bf-headline">Choose how you want to practice.</h1>
      </div>

      <div class="bf-options" id="bfOptions" role="group" aria-label="Practice type">
        {practiceOptions.map((opt) => (
          <button
            class="bf-option"
            data-key={opt.key}
            type="button"
            aria-pressed="false"
          >
            <span class="bf-option__arrow" aria-hidden="true">→</span>
            <span class="bf-option__label">{opt.label}</span>
            <span class="bf-option__desc">{opt.desc}</span>
          </button>
        ))}
      </div>

    </div>
  </div>

  <!-- ── STEP 2: Contact form ──────────────────────────────────── -->
  <div class="bf-step bf-step--hidden" id="bfStep2">
    <div class="bf-step__inner bf-step2__inner">

      <!-- Top nav bar: ← CHANGE SELECTION  • SELECTED · 1:1 COACHING -->
      <div class="bf-step2-nav">
        <button class="bf-back" id="bfBack" type="button">
          <span class="bf-back__arrow" aria-hidden="true">←</span> Change selection
        </button>
        <span class="bf-step2-badge" id="bfSelectedBadge"></span>
      </div>

      <!-- 2-col: heading+body left, offering card right -->
      <div class="bf-step2-cols">

        <div class="bf-step2-left">
          <h1 class="bf-step2-heading">Begin your<br>practice.</h1>
          <p class="bf-step2-sub">A few details. You'll be on Taylor's calendar in less than a minute. There's no obligation — the first conversation is a fit-check, not a sales call.</p>
        </div>

        <div class="bf-step2-right">

          <!-- 1:1 -->
          <div class="bf-offering bf-offering--hidden" id="bfOffering1on1">
            <div class="bf-offering-card">
              <span class="bf-offering-card__eyebrow">01 / The 1:1 Practice</span>
              <h3 class="bf-offering-card__title">A practice designed around you, in 60-minute sessions.</h3>
              <div class="bf-offering-card__grid">
                <div class="bf-offering-card__section">
                  <span class="bf-offering-card__label">Structure</span>
                  <p class="bf-offering-card__body">Monthly subscription. 60-minute virtual sessions. Three-month minimum arc, ongoing thereafter.</p>
                </div>
                <div class="bf-offering-card__section">
                  <span class="bf-offering-card__label">What we work with</span>
                  <p class="bf-offering-card__body">Whatever is alive in your work and life. Direction, ambition, transition, relationships, resistance, capacity.</p>
                </div>
                <div class="bf-offering-card__section">
                  <span class="bf-offering-card__label">Between sessions</span>
                  <p class="bf-offering-card__body">Ten to twenty minutes of daily practice. Reflection, exercises, intentional action.</p>
                </div>
                <div class="bf-offering-card__section">
                  <span class="bf-offering-card__label">AI-supported practice</span>
                  <p class="bf-offering-card__body">Optional. Session transcripts and pattern recognition support continuity across the arc.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Orgs & Teams -->
          <div class="bf-offering bf-offering--hidden" id="bfOfferingOrgs">
            <div class="bf-offering-card">
              <span class="bf-offering-card__eyebrow">02 / Orgs &amp; Teams</span>
              <h3 class="bf-offering-card__title">Custom programs for organizations, leadership teams, and cohorts.</h3>
              <div class="bf-offering-card__grid">
                <div class="bf-offering-card__section">
                  <span class="bf-offering-card__label">Structure</span>
                  <p class="bf-offering-card__body">Custom workshops, offsites, and coaching engagements. Virtual or in-person depending on the engagement.</p>
                </div>
                <div class="bf-offering-card__section">
                  <span class="bf-offering-card__label">What we practice</span>
                  <p class="bf-offering-card__body">Conscious change in how teams work, relate, and create. Clarity, coherence, and aligned direction.</p>
                </div>
                <div class="bf-offering-card__section">
                  <span class="bf-offering-card__label">Engagement types</span>
                  <p class="bf-offering-card__body">Executive coaching, team workshops, retreats and offsites, co-founder programs.</p>
                </div>
                <div class="bf-offering-card__section">
                  <span class="bf-offering-card__label">Facilitation &amp; support</span>
                  <p class="bf-offering-card__body">Designed and facilitated directly by a coach. Practical frameworks integrated into real workflows.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Group -->
          <div class="bf-offering bf-offering--hidden" id="bfOfferingGroup">
            <div class="bf-offering-card">
              <span class="bf-offering-card__eyebrow">03 / Group</span>
              <h3 class="bf-offering-card__title">A shared practice in community with structure and coach facilitation.</h3>
              <div class="bf-offering-card__grid">
                <div class="bf-offering-card__section">
                  <span class="bf-offering-card__label">Structure</span>
                  <p class="bf-offering-card__body">12-week guided group practice. Limited to 8 participants. 90-minute virtual sessions plus 3 individual coaching sessions.</p>
                </div>
                <div class="bf-offering-card__section">
                  <span class="bf-offering-card__label">What we practice</span>
                  <p class="bf-offering-card__body">Conscious change in how we work, relate, and create. Expanding possibility through shared practice and accountability.</p>
                </div>
                <div class="bf-offering-card__section">
                  <span class="bf-offering-card__label">Experience</span>
                  <p class="bf-offering-card__body">Community with waymakers navigating growth, change, and transition. Shared learning and supportive accountability.</p>
                </div>
                <div class="bf-offering-card__section">
                  <span class="bf-offering-card__label">Facilitation &amp; support</span>
                  <p class="bf-offering-card__body">Coach-led structure and facilitation. Practical frameworks, reflection, and AI-supported follow-ups.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Self-led: no offering card -->
          <div class="bf-offering bf-offering--hidden" id="bfOfferingSelflead"></div>

        </div>
      </div>

      <!-- Form -->
      <h2 class="bf-about-heading" id="bfAboutHeading">About you</h2>

      <!-- Netlify Forms — hidden form for build-time detection -->
      <form name="begin" netlify netlify-honeypot="bot-field" hidden>
        <input type="text" name="first-name" />
        <input type="email" name="email" />
        <input type="tel" name="phone" />
        <input type="hidden" name="option" />
      </form>

      <form class="bf-form" id="bfForm" novalidate>
        <input type="hidden" name="form-name" value="begin" />
        <input type="hidden" name="option" id="bfOptionInput" />
        <p class="bf-honeypot" aria-hidden="true">
          <label>Don't fill this out: <input name="bot-field" tabindex="-1" autocomplete="off" /></label>
        </p>

        <div class="bf-field">
          <label class="bf-label" for="bfFirstName">First name</label>
          <input
            class="bf-input"
            id="bfFirstName"
            name="first-name"
            type="text"
            autocomplete="given-name"
            required
            placeholder="Your first name"
          />
          <span class="bf-field-error" id="bfFirstNameError">Please enter your first name</span>
        </div>

        <div class="bf-field">
          <label class="bf-label" for="bfEmail">Email</label>
          <input
            class="bf-input"
            id="bfEmail"
            name="email"
            type="email"
            autocomplete="email"
            required
            placeholder="you@example.com"
            inputmode="email"
          />
          <span class="bf-field-error" id="bfEmailError">Please enter a valid email address</span>
        </div>

        <div class="bf-field">
          <label class="bf-label" for="bfPhone">
            Phone <span class="bf-optional">(optional)</span>
          </label>
          <input
            class="bf-input"
            id="bfPhone"
            name="phone"
            type="tel"
            autocomplete="tel"
            placeholder="+1 (206) 555-0100"
            inputmode="tel"
          />
        </div>

        <div class="bf-form-footer">
          <button class="bf-submit" id="bfSubmit" type="button">
            <span class="bf-submit__label" id="bfSubmitLabel">Begin Practice →</span>
            <span class="bf-submit__spinner" aria-hidden="true"></span>
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- ── STEP 3: Downstream ────────────────────────────────────── -->
  <div class="bf-step bf-step--hidden" id="bfStep3">
    <div class="bf-step__inner">

      <!-- 3a: Calendly embed (shown for 1:1, group, orgs) -->
      <div class="bf-calendly-wrap" id="bfCalendlyWrap">
        <div class="bf-header">
          <span class="bf-eyebrow" id="bfCalendlyEyebrow"></span>
          <h2 class="bf-headline">Book your call</h2>
          <p class="bf-subhead">Pick a time that works for you — Taylor will confirm shortly after.</p>
        </div>
        <div id="bfCalendlyMount"></div>
      </div>

      <!-- 3b: Self-led confirmation -->
      <div class="bf-selflead-wrap bf-step--hidden" id="bfSelfleadWrap">
        <div class="bf-selflead">
          <span class="bf-eyebrow">Self-led practice</span>
          <h2 class="bf-headline bf-selflead__headline">You're on the list.</h2>
          <p class="bf-selflead__body">
            Thank you for your interest. Our self-led practice will be available
            <strong>Winter 2026</strong> — we'll be in touch with everything you
            need to begin.
          </p>
          <a href="/" class="bf-selflead__home t-cta">Return to Every Day Future →</a>
        </div>
      </div>

    </div>
  </div>

</div>

<style>
/* ── Flow container */
.begin-flow {
  width: 100%;
  min-height: calc(100vh - 80px);
  display: flex;
  flex-direction: column;
}

/* ── Steps */
.bf-step {
  flex: 1;
  display: flex;
  flex-direction: column;
  animation: bfFadeIn 0.45s cubic-bezier(0.16, 1, 0.3, 1) both;
}
.bf-step--hidden {
  display: none !important;
}

@keyframes bfFadeIn {
  from { opacity: 0; transform: translateY(18px); }
  to   { opacity: 1; transform: translateY(0); }
}

.bf-step__inner {
  position: relative;
  width: 100%;
  max-width: 680px;
  margin: 0 auto;
  padding: 72px var(--gutter) 80px;
  flex: 1;
  display: flex;
  flex-direction: column;
}

/* ── Header block (Step 1 / Step 3) */
.bf-header {
  margin-bottom: 36px;
}

.bf-eyebrow {
  display: block;
  font-family: var(--font-mono);
  font-size: 13px;
  letter-spacing: 0.110em;
  text-transform: uppercase;
  color: rgba(0,0,0,0.40);
  margin-bottom: 18px;
}

/* Step 1 headline / Step 3 headline */
.bf-headline {
  font-family: var(--font-body);
  font-weight: 400;
  font-size: clamp(46px, 5.2vw, 80px);
  letter-spacing: -0.030em;
  line-height: 1.0;
  color: var(--ink);
}

.bf-subhead {
  margin-top: 14px;
  font-family: var(--font-body);
  font-weight: 300;
  font-size: 14px;
  line-height: 24px;
  letter-spacing: 0.020em;
  color: rgba(0,0,0,0.50);
}

/* Step 1 inner is full-width so cards span page */
#bfStep1 .bf-step__inner {
  max-width: var(--max-w);
}

/* ── Step 2 inner — wider to accommodate 2-col */
.bf-step2__inner {
  max-width: var(--max-w) !important;
}

/* ── Step 2 nav bar */
.bf-step2-nav {
  display: flex;
  align-items: center;
  gap: 24px;
  padding-bottom: 20px;
  margin-bottom: 60px;
  border-bottom: 0.5px solid rgba(0,0,0,0.12);
}

.bf-step2-badge {
  font-family: var(--font-mono);
  font-size: 13px;
  letter-spacing: 0.110em;
  text-transform: uppercase;
  color: rgba(0,0,0,0.40);
}
.bf-step2-badge:not(:empty)::before {
  content: '•';
  margin-right: 10px;
  color: rgba(0,0,0,0.25);
}
.bf-step2-badge:empty { display: none; }

/* ── Step 2 two-column layout */
.bf-step2-cols {
  display: grid;
  grid-template-columns: 2fr 3fr;
  gap: 80px;
  margin-bottom: 72px;
  align-items: start;
}

.bf-step2-heading {
  font-family: var(--font-body);
  font-weight: 400;
  font-size: clamp(46px, 5.2vw, 80px);
  letter-spacing: -0.030em;
  line-height: 1.0;
  color: var(--ink);
  margin-bottom: 28px;
}

.bf-step2-sub {
  font-family: var(--font-body);
  font-weight: 300;
  font-size: 14px;
  line-height: 24px;
  letter-spacing: 0.020em;
  color: rgba(0,0,0,0.55);
}

/* ── Offering card (right column) */
.bf-offering-card {
  background: var(--paper);
  padding: 32px;
}

.bf-offering-card__eyebrow {
  display: block;
  font-family: var(--font-mono);
  font-size: 13px;
  letter-spacing: 0.110em;
  text-transform: uppercase;
  color: rgba(0,0,0,0.40);
  margin-bottom: 16px;
}

.bf-offering-card__title {
  font-family: var(--font-body);
  font-weight: 400;
  font-size: clamp(18px, 1.8vw, 26px);
  line-height: 1.25;
  letter-spacing: -0.010em;
  color: var(--ink);
  margin-bottom: 24px;
  padding-bottom: 24px;
  border-bottom: 0.5px solid rgba(0,0,0,0.12);
}

.bf-offering-card__grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0;
}

.bf-offering-card__section {
  padding: 20px 20px 20px 0;
  border-bottom: 0.5px solid rgba(0,0,0,0.10);
}
.bf-offering-card__section:nth-child(even) {
  padding-left: 20px;
  padding-right: 0;
  border-left: 0.5px solid rgba(0,0,0,0.10);
}
.bf-offering-card__section:nth-last-child(-n+2) {
  border-bottom: none;
}

.bf-offering-card__label {
  display: block;
  font-family: var(--font-mono);
  font-size: 13px;
  letter-spacing: 0.110em;
  text-transform: uppercase;
  color: rgba(0,0,0,0.40);
  margin-bottom: 10px;
}

.bf-offering-card__body {
  font-family: var(--font-body);
  font-weight: 300;
  font-size: 14px;
  line-height: 24px;
  letter-spacing: 0.020em;
  color: rgba(0,0,0,0.65);
}

/* ── "About you" heading */
.bf-about-heading {
  font-family: var(--font-body);
  font-weight: 400;
  font-size: clamp(22px, 2.2vw, 32px);
  line-height: 1.2;
  letter-spacing: -0.010em;
  color: var(--ink);
  margin-bottom: 8px;
}

/* ── Step 1 option grid — 4-up matching S2 cards */
.bf-options {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 4px;
}

.bf-option {
  position: relative;
  display: flex;
  flex-direction: column;
  gap: 12px;
  padding: 28px 24px 32px;
  background: var(--paper);
  border: 0.5px solid rgba(0,0,0,0.10);
  cursor: pointer;
  text-align: left;
  transition: background 0.22s ease, color 0.22s ease;
}

.bf-option__arrow {
  position: absolute;
  top: 28px;
  right: 24px;
  font-family: var(--font-body);
  font-size: 22px;
  color: rgba(0,0,0,0.30);
  line-height: 1;
  transition: color 0.22s ease, transform 0.22s ease;
}

.bf-option__label {
  font-family: var(--font-body);
  font-weight: 400;
  font-size: 32px;
  letter-spacing: -0.020em;
  line-height: 1.05;
  color: var(--ink);
  transition: color 0.22s ease;
}

.bf-option__desc {
  font-family: var(--font-body);
  font-weight: 300;
  font-size: 13px;
  line-height: 22px;
  letter-spacing: 0.020em;
  color: rgba(0,0,0,0.55);
  transition: color 0.22s ease;
}

/* Hover: full ink invert */
.bf-option:hover { background: var(--ink); }
.bf-option:hover .bf-option__label { color: var(--paper); }
.bf-option:hover .bf-option__desc  { color: rgba(255,255,255,0.62); }
.bf-option:hover .bf-option__arrow {
  color: var(--blue);
  transform: translateX(4px);
}

/* Selected state */
.bf-option[aria-pressed="true"] { background: var(--ink); }
.bf-option[aria-pressed="true"] .bf-option__label { color: var(--paper); }
.bf-option[aria-pressed="true"] .bf-option__desc  { color: rgba(255,255,255,0.62); }
.bf-option[aria-pressed="true"] .bf-option__arrow { color: var(--blue); }

/* ── Back button */
.bf-back {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 0;
  color: rgba(0,0,0,0.35);
  font-family: var(--font-mono);
  font-size: 13px;
  letter-spacing: 0.110em;
  text-transform: uppercase;
  transition: color 0.2s ease;
}
.bf-back:hover { color: var(--ink); }
.bf-back__arrow { font-size: 14px; }

/* ── Offering block visibility */
.bf-offering--hidden { display: none; }

/* ── Form */
.bf-form {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.bf-honeypot {
  position: absolute;
  left: -9999px;
  opacity: 0;
  pointer-events: none;
}

.bf-field {
  display: flex;
  flex-direction: column;
  padding: 20px 0 22px;
  border-bottom: 0.5px solid rgba(0,0,0,0.12);
}
.bf-field:first-of-type { border-top: 0.5px solid rgba(0,0,0,0.12); }

.bf-label {
  font-family: var(--font-mono);
  font-size: 13px;
  letter-spacing: 0.110em;
  text-transform: uppercase;
  color: rgba(0,0,0,0.45);
  margin-bottom: 10px;
}

.bf-optional {
  font-family: var(--font-mono);
  font-size: 13px;
  letter-spacing: 0.110em;
  text-transform: uppercase;
  color: rgba(0,0,0,0.28);
}

.bf-input {
  background: transparent;
  border: none;
  border-bottom: 0.5px solid rgba(0,0,0,0.30);
  outline: none;
  font-family: var(--font-body);
  font-weight: 300;
  font-size: 16px;
  letter-spacing: 0.020em;
  color: var(--ink);
  padding: 8px 0 10px;
  width: 100%;
  transition: border-color 0.2s ease;
  -webkit-appearance: none;
  border-radius: 0;
}
.bf-input::placeholder { color: rgba(0,0,0,0.28); }
.bf-input:focus { border-bottom-color: var(--blue); }
.bf-input.bf-input--error { border-bottom-color: var(--ink); }

.bf-field-error {
  display: none;
  font-family: var(--font-mono);
  font-size: 13px;
  letter-spacing: 0.110em;
  text-transform: uppercase;
  color: var(--ink);
  opacity: 0.55;
  margin-top: 8px;
}
.bf-field-error.visible { display: block; }

/* ── Form footer */
.bf-form-footer {
  margin-top: 40px;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 16px;
}

/* ── Submit button */
.bf-submit {
  position: relative;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 48px;
  padding: 0 40px;
  background: var(--ink);
  color: var(--paper);
  border: none;
  border-radius: 4px;
  cursor: pointer;
  transition: background 0.25s ease;
  min-width: 140px;
}
.bf-submit:hover { background: var(--blue); }
.bf-submit:disabled { opacity: 0.50; cursor: default; background: var(--ink); }

.bf-submit__label {
  font-family: var(--font-mono);
  font-size: 14.4px;
  letter-spacing: 0.110em;
  text-transform: uppercase;
  transition: opacity 0.2s;
}
.bf-submit.loading .bf-submit__label { opacity: 0; }

.bf-submit__spinner {
  display: none;
  position: absolute;
  width: 18px;
  height: 18px;
  border: 1.5px solid rgba(255,255,255,0.3);
  border-top-color: #fff;
  border-radius: 50%;
  animation: bfSpin 0.7s linear infinite;
}
.bf-submit.loading .bf-submit__spinner { display: block; }

@keyframes bfSpin {
  to { transform: rotate(360deg); }
}

.bf-form-note {
  font-family: var(--font-body);
  font-weight: 300;
  font-size: 14px;
  line-height: 24px;
  letter-spacing: 0.020em;
  color: rgba(0,0,0,0.38);
}

/* ── Step 3: Calendly */
.bf-calendly-wrap .bf-header {
  margin-bottom: 36px;
}

#bfCalendlyMount {
  margin: 0 calc(-1 * var(--gutter));
}

/* ── Step 3: Self-led */
.bf-selflead {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.bf-selflead__headline {
  margin-top: 8px;
  margin-bottom: 24px;
}

.bf-selflead__body {
  font-family: var(--font-body);
  font-weight: 300;
  font-size: 14px;
  line-height: 24px;
  letter-spacing: 0.020em;
  color: rgba(0,0,0,0.60);
  max-width: 460px;
  margin-bottom: 44px;
}
.bf-selflead__body strong {
  color: var(--ink);
  font-weight: 400;
}

.bf-selflead__home {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-family: var(--font-mono);
  font-size: 13px;
  letter-spacing: 0.110em;
  text-transform: uppercase;
  color: rgba(0,0,0,0.40);
  text-decoration: none;
  border-bottom: 0.5px solid transparent;
  padding-bottom: 2px;
  transition: color 0.2s, border-color 0.2s;
}
.bf-selflead__home:hover {
  color: var(--ink);
  border-bottom-color: rgba(0,0,0,0.30);
}

/* ── Tablet ≤ 900px */
@media (max-width: 900px) {
  .bf-options { grid-template-columns: repeat(2, 1fr); }
  #bfStep1 .bf-step__inner { max-width: 100%; }
}

/* ── Mobile ≤ 640px */
@media (max-width: 640px) {

  /* Step 1 */
  #bfStep1 { flex: none; }
  #bfStep1 .bf-step__inner {
    padding-top: 20px;
    padding-bottom: 40px;
    min-height: 0;
  }
  #bfStep1 .bf-header { margin-bottom: 16px; }

  /* Step 1 cards: 1-up on mobile */
  .bf-options { grid-template-columns: 1fr; }
  .bf-option__label { font-size: 28px; }

  /* Step 2 */
  #bfStep2 .bf-step__inner {
    padding-top: 28px;
    padding-bottom: 40px;
  }

  /* Page headline */
  .bf-headline { font-size: 34px; }
  .bf-step2-heading { font-size: 34px; }

  /* Step 2 nav */
  .bf-step2-nav { margin-bottom: 32px; }

  /* Step 2: stack columns on mobile */
  .bf-step2-cols {
    grid-template-columns: 1fr;
    gap: 32px;
    margin-bottom: 40px;
  }

  /* Offering card grid: 1-col on mobile */
  .bf-offering-card { padding: 20px; }
  .bf-offering-card__grid { grid-template-columns: 1fr; }
  .bf-offering-card__section:nth-child(even) {
    padding-left: 0;
    border-left: none;
  }
  .bf-offering-card__section:nth-last-child(-n+2) {
    border-bottom: 0.5px solid rgba(0,0,0,0.10);
  }
  .bf-offering-card__section:last-child {
    border-bottom: none;
  }

  /* About heading */
  .bf-about-heading { font-size: 22px; margin-bottom: 4px; }

  /* Form fields */
  .bf-field { padding: 12px 0 14px; }
  .bf-label { margin-bottom: 4px; }

  #bfCalendlyMount { margin: 0 calc(-1 * var(--gutter)); }
}


</style>

<script is:inline>
(function () {

  var bfData = document.getElementById('bfData');
  var OPTION_LABELS = JSON.parse(bfData.dataset.labels);
  var CALENDLY_URLS = JSON.parse(bfData.dataset.urls);

  // ── State
  var selectedOption = null;

  // ── Elements
  var step1       = document.getElementById('bfStep1');
  var step2       = document.getElementById('bfStep2');
  var step3       = document.getElementById('bfStep3');
  var optionBtns  = document.querySelectorAll('.bf-option');
  var backBtn     = document.getElementById('bfBack');
  var badge       = document.getElementById('bfSelectedBadge');
  var optionInput = document.getElementById('bfOptionInput');
  var form        = document.getElementById('bfForm');
  var submitBtn   = document.getElementById('bfSubmit');

  var advanceTimer = null;

  // ── Read URL param on load
  var params = new URLSearchParams(window.location.search);
  var paramOption = params.get('option');
  if (paramOption && OPTION_LABELS[paramOption]) {
    selectOption(paramOption, true);
  }

  // ── Option selection
  optionBtns.forEach(function (btn) {
    btn.addEventListener('click', function () {
      selectOption(btn.dataset.key, false);
    });
  });

  function selectOption(key, immediate) {
    selectedOption = key;
    optionBtns.forEach(function (btn) {
      var pressed = btn.dataset.key === key;
      btn.setAttribute('aria-pressed', pressed ? 'true' : 'false');
    });
    clearTimeout(advanceTimer);
    advanceTimer = setTimeout(function () {
      badge.textContent = OPTION_LABELS[selectedOption] || '';
      optionInput.value = selectedOption;
      document.documentElement.classList.remove('bf-has-param');

      // Show/hide offering details; reset any open accordion on switch
      var allOfferings = ['bfOffering1on1','bfOfferingOrgs','bfOfferingGroup','bfOfferingSelflead'];
      var keyMap = { '1on1':'bfOffering1on1', 'orgs':'bfOfferingOrgs', 'group':'bfOfferingGroup', 'selflead':'bfOfferingSelflead' };
      allOfferings.forEach(function(id) {
        var el = document.getElementById(id);
        if (!el) return;
        var isActive = keyMap[selectedOption] === id;
        el.classList.toggle('bf-offering--hidden', !isActive);
        // Collapse sections when switching options
        if (!isActive) {
          el.classList.remove('bf-offering--expanded');
          var tog = el.querySelector('.bf-offering__toggle');
          if (tog) tog.setAttribute('aria-expanded', 'false');
          var icon = el.querySelector('.bf-offering__toggle-icon');
          if (icon) icon.textContent = '+';
        }
      });

      showStep(step2);
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }, immediate ? 0 : 350);
  }

  // ── Back → Step 1
  backBtn.addEventListener('click', function () {
    showStep(step1);
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });

  // ── Offering accordion toggle
  document.querySelectorAll('.bf-offering__toggle').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var offering = btn.closest('.bf-offering');
      var expanded = offering.classList.toggle('bf-offering--expanded');
      btn.setAttribute('aria-expanded', String(expanded));
      btn.querySelector('.bf-offering__toggle-icon').textContent = expanded ? '+' : '+';
    });
  });

  // ── Form submission
  submitBtn.addEventListener('click', function () {
    if (!validateForm()) return;

    submitBtn.disabled = true;
    submitBtn.classList.add('loading');

    var data = new URLSearchParams();
    data.append('form-name', 'begin');
    data.append('first-name', document.getElementById('bfFirstName').value.trim());
    data.append('email',      document.getElementById('bfEmail').value.trim());
    data.append('phone',      document.getElementById('bfPhone').value.trim());
    data.append('option',     selectedOption);

    // Fire and forget — don't block the user on the network outcome
    try {
      fetch('/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: data.toString(),
      });
    } catch (e) {}

    advanceToStep3();
  });

  function validateForm() {
    var valid = true;

    var firstName = document.getElementById('bfFirstName');
    var firstNameErr = document.getElementById('bfFirstNameError');
    if (!firstName.value.trim()) {
      firstName.classList.add('bf-input--error');
      firstNameErr.classList.add('visible');
      valid = false;
    } else {
      firstName.classList.remove('bf-input--error');
      firstNameErr.classList.remove('visible');
    }

    var email = document.getElementById('bfEmail');
    var emailErr = document.getElementById('bfEmailError');
    var emailOk = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email.value.trim());
    if (!emailOk) {
      email.classList.add('bf-input--error');
      emailErr.classList.add('visible');
      valid = false;
    } else {
      email.classList.remove('bf-input--error');
      emailErr.classList.remove('visible');
    }

    return valid;
  }

  function advanceToStep3() {
    var calendlyMount  = document.getElementById('bfCalendlyMount');
    var calendlyWrap   = document.getElementById('bfCalendlyWrap');
    var selfleadWrap   = document.getElementById('bfSelfleadWrap');
    var calendlyEyebrow = document.getElementById('bfCalendlyEyebrow');

    if (selectedOption === 'selflead') {
      calendlyWrap.classList.add('bf-step--hidden');
      selfleadWrap.classList.remove('bf-step--hidden');
    } else {
      var url = CALENDLY_URLS[selectedOption];
      if (url && calendlyMount) {
        var primaryColor = '2956e0';
        var fullUrl = url + '?hide_gdpr_banner=1&primary_color=' + primaryColor + '&text_color=000000&background_color=ffffff';
        var widget = document.createElement('div');
        widget.className = 'calendly-inline-widget';
        widget.setAttribute('data-url', fullUrl);
        widget.style.minWidth = '280px';
        widget.style.height   = '700px';
        calendlyMount.appendChild(widget);

        if (typeof Calendly === 'undefined') {
          var s = document.createElement('script');
          s.src = 'https://assets.calendly.com/assets/external/widget.js';
          s.async = true;
          document.head.appendChild(s);
        } else {
          Calendly.initInlineWidgets();
        }
      }
      if (calendlyEyebrow) {
        calendlyEyebrow.textContent = OPTION_LABELS[selectedOption] || '';
      }
      selfleadWrap.classList.add('bf-step--hidden');
      calendlyWrap.classList.remove('bf-step--hidden');
    }

    showStep(step3);
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  function showStep(target) {
    // Always clear bf-has-param so its high-specificity display rules can't interfere
    document.documentElement.classList.remove('bf-has-param');

    [step1, step2, step3].forEach(function (s) {
      if (s === target) {
        s.classList.remove('bf-step--hidden');
        s.style.removeProperty('display');
        // Re-trigger animation
        s.style.animation = 'none';
        s.offsetHeight; // reflow
        s.style.animation = '';
      } else {
        s.classList.add('bf-step--hidden');
        // Inline !important overrides any stylesheet rule including bf-has-param
        s.style.setProperty('display', 'none', 'important');
      }
    });
  }

  // ── Clear validation on input
  ['bfFirstName', 'bfEmail'].forEach(function (id) {
    var el = document.getElementById(id);
    if (el) {
      el.addEventListener('input', function () {
        el.classList.remove('bf-input--error');
        var errEl = document.getElementById(id + 'Error');
        if (errEl) errEl.classList.remove('visible');
      });
    }
  });

})();
</script>
