---
import Calendly from './Calendly.astro';

const options = [
  { key: '1on1',    label: '1:1 Coaching',   desc: 'One-on-one practice with a dedicated coach' },
  { key: 'group',   label: 'Group Coaching', desc: 'Shared practice in community with a coach' },
  { key: 'orgs',    label: 'Orgs & Teams',   desc: 'Coaching practice for organisations and teams' },
  { key: 'selflead',label: 'Self-led',        desc: 'Practice on your own with structure and guidance' },
];

const calendlyUrls: Record<string, string> = {
  '1on1':    'https://calendly.com/placeholder-60',
  'group':   'https://calendly.com/placeholder-15',
  'orgs':    'https://calendly.com/placeholder-60',
  'selflead': '',
};
---

<div class="begin-flow" id="beginFlow">

  <!-- ── STEP 1: Option selection ─────────────────────────────── -->
  <div class="bf-step" id="bfStep1">
    <div class="bf-step__inner">

      <div class="bf-header">
        <h1 class="bf-headline">Choose your way</h1>
      </div>

      <div class="bf-options" id="bfOptions" role="group" aria-label="Practice type">
        {options.map((opt) => (
          <button
            class="bf-option"
            data-key={opt.key}
            type="button"
            aria-pressed="false"
          >
            <span class="bf-option__label">{opt.label}</span>
            <span class="bf-option__desc">{opt.desc}</span>
            <span class="bf-option__arrow" aria-hidden="true">→</span>
          </button>
        ))}
      </div>

    </div>
  </div>

  <!-- ── STEP 2: Contact form ──────────────────────────────────── -->
  <div class="bf-step bf-step--hidden" id="bfStep2">
    <div class="bf-step__inner">

      <div class="bf-header">
        <div class="bf-top-nav">
          <button class="bf-back" id="bfBack" type="button">
            <span class="bf-back__arrow" aria-hidden="true">←</span>
            <span class="t-cta">Change selection</span>
          </button>
          <div class="bf-selected-badge" id="bfSelectedBadge"></div>
        </div>
        <h2 class="bf-headline">About you</h2>
      </div>

      <!-- Netlify Forms — hidden form for build-time detection -->
      <form name="begin" netlify netlify-honeypot="bot-field" hidden>
        <input type="text" name="first-name" />
        <input type="email" name="email" />
        <input type="tel" name="phone" />
        <input type="hidden" name="option" />
      </form>

      <form class="bf-form" id="bfForm" novalidate>
        <input type="hidden" name="form-name" value="begin" />
        <input type="hidden" name="option" id="bfOptionInput" />
        <p class="bf-honeypot" aria-hidden="true">
          <label>Don't fill this out: <input name="bot-field" tabindex="-1" autocomplete="off" /></label>
        </p>

        <div class="bf-field">
          <label class="bf-label" for="bfFirstName">First name</label>
          <input
            class="bf-input"
            id="bfFirstName"
            name="first-name"
            type="text"
            autocomplete="given-name"
            required
            placeholder="Your first name"
          />
          <span class="bf-field-error" id="bfFirstNameError">Please enter your first name</span>
        </div>

        <div class="bf-field">
          <label class="bf-label" for="bfEmail">Email address</label>
          <input
            class="bf-input"
            id="bfEmail"
            name="email"
            type="email"
            autocomplete="email"
            required
            placeholder="you@example.com"
            inputmode="email"
          />
          <span class="bf-field-error" id="bfEmailError">Please enter a valid email address</span>
        </div>

        <div class="bf-field">
          <label class="bf-label" for="bfPhone">
            Phone <span class="bf-optional">(optional)</span>
          </label>
          <input
            class="bf-input"
            id="bfPhone"
            name="phone"
            type="tel"
            autocomplete="tel"
            placeholder="+1 (206) 555-0100"
            inputmode="tel"
          />
        </div>

        <div class="bf-form-footer">
          <button class="bf-submit" id="bfSubmit" type="submit">
            <span class="bf-submit__label t-cta">Begin</span>
            <span class="bf-submit__spinner" aria-hidden="true"></span>
          </button>
        </div>

      </form>
    </div>
  </div>

  <!-- ── STEP 3: Downstream ────────────────────────────────────── -->
  <div class="bf-step bf-step--hidden" id="bfStep3">
    <div class="bf-step__inner">

      <!-- 3a: Calendly embed (shown for 1:1, group, orgs) -->
      <div class="bf-calendly-wrap" id="bfCalendlyWrap">
        <div class="bf-header">
          <span class="bf-eyebrow" id="bfCalendlyEyebrow"></span>
          <h2 class="bf-headline">Book your call</h2>
          <p class="bf-subhead">Pick a time that works for you — Taylor will confirm shortly after.</p>
        </div>
        <div id="bfCalendlyMount"></div>
      </div>

      <!-- 3b: Self-led confirmation -->
      <div class="bf-selflead-wrap bf-step--hidden" id="bfSelfleadWrap">
        <div class="bf-selflead">
          <div class="bf-selflead__mark" aria-hidden="true">
            <img src="/marks/Vector-5.svg" alt="" width="200" />
          </div>
          <span class="bf-eyebrow">Self-led practice</span>
          <h2 class="bf-headline bf-selflead__headline">You're on the list.</h2>
          <p class="bf-selflead__body">
            Thank you for your interest. Our self-led practice will be available
            <strong>Winter 2026</strong> — we'll be in touch with everything you
            need to begin.
          </p>
          <a href="/" class="bf-selflead__home t-cta">Back to Every Day Future →</a>
        </div>
      </div>

    </div>
  </div>

</div>

<style>
/* ── Flow container */
.begin-flow {
  width: 100%;
  min-height: calc(100vh - 80px);
  display: flex;
  flex-direction: column;
}

/* ── Steps */
.bf-step {
  flex: 1;
  display: flex;
  flex-direction: column;
  animation: bfFadeIn 0.45s cubic-bezier(0.16, 1, 0.3, 1) both;
}
.bf-step--hidden {
  display: none !important;
}

@keyframes bfFadeIn {
  from { opacity: 0; transform: translateY(18px); }
  to   { opacity: 1; transform: translateY(0); }
}

.bf-step__inner {
  width: 100%;
  max-width: 680px;
  margin: 0 auto;
  padding: 72px var(--gutter) 80px;
  flex: 1;
  display: flex;
  flex-direction: column;
}

/* ── Header block */
.bf-header {
  margin-bottom: 52px;
}

.bf-eyebrow {
  display: block;
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: 0.180em;
  text-transform: uppercase;
  color: rgba(0,0,0,0.40);
  margin-bottom: 18px;
}

.bf-headline {
  font-family: var(--font-body);
  font-weight: 300;
  font-size: clamp(38px, 6vw, 62px);
  letter-spacing: -0.030em;
  line-height: 1.05;
  color: var(--ink);
}

.bf-subhead {
  margin-top: 14px;
  font-family: var(--font-body);
  font-weight: 300;
  font-size: 15px;
  line-height: 1.7;
  letter-spacing: 0.010em;
  color: rgba(0,0,0,0.50);
}

/* ── Option buttons */
.bf-options {
  display: flex;
  flex-direction: column;
  border-top: 0.5px solid rgba(0,0,0,0.14);
  margin-bottom: 0;
}

.bf-option {
  display: grid;
  grid-template-columns: 1fr auto;
  grid-template-rows: auto auto;
  align-items: center;
  column-gap: 20px;
  padding: 26px 0;
  border: none;
  border-bottom: 0.5px solid rgba(0,0,0,0.14);
  background: transparent;
  cursor: pointer;
  text-align: left;
  transition: background 0.22s ease, padding-left 0.22s ease, padding-right 0.22s ease;
  margin: 0 calc(-1 * var(--gutter));
  padding-left: var(--gutter);
  padding-right: var(--gutter);
}

.bf-option__label {
  font-family: var(--font-body);
  font-weight: 300;
  font-size: clamp(28px, 5.5vw, 44px);
  letter-spacing: -0.020em;
  line-height: 1.05;
  color: var(--ink);
  transition: color 0.22s ease;
  grid-column: 1;
  grid-row: 1;
}

.bf-option__desc {
  font-family: var(--font-body);
  font-size: 13px;
  line-height: 1.5;
  letter-spacing: 0.010em;
  color: rgba(0,0,0,0.42);
  transition: color 0.22s ease;
  margin-top: 4px;
  grid-column: 1;
  grid-row: 2;
}

.bf-option__arrow {
  font-family: var(--font-body);
  font-size: 24px;
  color: rgba(0,0,0,0.22);
  transition: color 0.22s ease, transform 0.22s ease;
  grid-column: 2;
  grid-row: 1 / 3;
  align-self: center;
}

/* Hover state */
.bf-option:hover {
  background: rgba(0,0,0,0.03);
}
.bf-option:hover .bf-option__label { color: var(--ink); }
.bf-option:hover .bf-option__arrow {
  color: rgba(0,0,0,0.50);
  transform: translateX(4px);
}

/* Selected state */
.bf-option[aria-pressed="true"] {
  background: var(--ink);
  padding-left: var(--gutter);
  padding-right: var(--gutter);
}
.bf-option[aria-pressed="true"] .bf-option__label { color: #fff; }
.bf-option[aria-pressed="true"] .bf-option__desc  { color: rgba(255,255,255,0.55); }
.bf-option[aria-pressed="true"] .bf-option__arrow {
  color: rgba(255,255,255,0.60);
  transform: none;
}

/* ── Back + badge stacked nav */
.bf-top-nav {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 14px;
  margin-bottom: 28px;
}

/* ── Back button */
.bf-back {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 0;
  color: rgba(0,0,0,0.40);
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: 0.140em;
  text-transform: uppercase;
  transition: color 0.2s ease;
}
.bf-back:hover { color: var(--ink); }
.bf-back__arrow { font-size: 14px; }

/* ── Selected badge */
.bf-selected-badge {
  display: inline-flex;
  align-items: center;
  height: 28px;
  padding: 0 14px;
  border: 0.5px solid rgba(0,0,0,0.22);
  border-radius: 4px;
  font-family: var(--font-mono);
  font-size: 10px;
  letter-spacing: 0.130em;
  text-transform: uppercase;
  color: rgba(0,0,0,0.50);
  margin-bottom: 18px;
}
.bf-selected-badge:empty { display: none; }

/* ── Form */
.bf-form {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.bf-honeypot {
  position: absolute;
  left: -9999px;
  opacity: 0;
  pointer-events: none;
}

.bf-field {
  display: flex;
  flex-direction: column;
  padding: 20px 0 22px;
}

.bf-label {
  font-family: var(--font-mono);
  font-size: 10px;
  letter-spacing: 0.160em;
  text-transform: uppercase;
  color: rgba(0,0,0,0.40);
  margin-bottom: 10px;
}

.bf-optional {
  font-family: var(--font-mono);
  font-size: 10px;
  letter-spacing: 0.100em;
  color: rgba(0,0,0,0.28);
  text-transform: none;
}

.bf-input {
  background: transparent;
  border: none;
  border-bottom: 0.5px solid rgba(0,0,0,0.18);
  outline: none;
  font-family: var(--font-body);
  font-weight: 300;
  font-size: 18px;
  letter-spacing: 0.005em;
  color: var(--ink);
  padding: 8px 0 10px;
  width: 100%;
  transition: border-color 0.2s ease;
  -webkit-appearance: none;
  border-radius: 0;
}
.bf-input::placeholder { color: rgba(0,0,0,0.22); }
.bf-input:focus { border-bottom-color: var(--ink); }
.bf-input.bf-input--error { border-bottom-color: var(--orange); }

.bf-field-error {
  display: none;
  font-family: var(--font-mono);
  font-size: 10px;
  letter-spacing: 0.110em;
  text-transform: uppercase;
  color: var(--orange);
  margin-top: 8px;
}
.bf-field-error.visible { display: block; }

/* ── Form footer */
.bf-form-footer {
  margin-top: 40px;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 16px;
}

/* ── Submit button */
.bf-submit {
  position: relative;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 48px;
  padding: 0 40px;
  background: var(--ink);
  color: var(--paper);
  border: none;
  border-radius: 100px;
  cursor: pointer;
  transition: background 0.25s ease;
  min-width: 140px;
}
.bf-submit:hover { background: var(--blue); }
.bf-submit:disabled { opacity: 0.50; cursor: default; background: var(--ink); }

.bf-submit__label {
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: 0.110em;
  text-transform: uppercase;
  transition: opacity 0.2s;
}
.bf-submit.loading .bf-submit__label { opacity: 0; }

.bf-submit__spinner {
  display: none;
  position: absolute;
  width: 18px;
  height: 18px;
  border: 1.5px solid rgba(255,255,255,0.3);
  border-top-color: #fff;
  border-radius: 50%;
  animation: bfSpin 0.7s linear infinite;
}
.bf-submit.loading .bf-submit__spinner { display: block; }

@keyframes bfSpin {
  to { transform: rotate(360deg); }
}

.bf-form-note {
  font-family: var(--font-body);
  font-weight: 300;
  font-size: 13px;
  letter-spacing: 0.010em;
  color: rgba(0,0,0,0.38);
}

/* ── Step 3: Calendly */
.bf-calendly-wrap .bf-header {
  margin-bottom: 36px;
}

#bfCalendlyMount {
  margin: 0 calc(-1 * var(--gutter));
}

/* ── Step 3: Self-led */
.bf-selflead {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  padding-top: 20px;
}

.bf-selflead__mark {
  margin-bottom: 36px;
  opacity: 0.18;
  filter: invert(1);
}

.bf-selflead__headline {
  margin-top: 8px;
  margin-bottom: 24px;
}

.bf-selflead__body {
  font-family: var(--font-body);
  font-weight: 300;
  font-size: 17px;
  line-height: 1.75;
  letter-spacing: 0.010em;
  color: rgba(0,0,0,0.60);
  max-width: 460px;
  margin-bottom: 44px;
}
.bf-selflead__body strong {
  color: var(--ink);
  font-weight: 400;
}

.bf-selflead__home {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: 0.140em;
  text-transform: uppercase;
  color: rgba(0,0,0,0.40);
  text-decoration: none;
  border-bottom: 0.5px solid transparent;
  padding-bottom: 2px;
  transition: color 0.2s, border-color 0.2s;
}
.bf-selflead__home:hover {
  color: var(--ink);
  border-bottom-color: rgba(0,0,0,0.30);
}

/* ── Mobile ≤ 640px */
@media (max-width: 640px) {
  .bf-step__inner {
    padding-top: 52px;
    padding-bottom: 60px;
  }
  .bf-header { margin-bottom: 36px; }
  .bf-option { padding-top: 22px; padding-bottom: 22px; }
  .bf-option__label { font-size: clamp(26px, 7.5vw, 38px); }
  .bf-option__desc  { font-size: 12px; }
  .bf-input { font-size: 16px; } /* prevent iOS zoom on focus */
  .bf-form-footer { margin-top: 32px; }
  #bfCalendlyMount { margin: 0 calc(-1 * var(--gutter)); }
}
</style>

<script is:inline>
(function () {

  var OPTION_LABELS = {
    '1on1':    '1:1 Coaching',
    'group':   'Group Coaching',
    'orgs':    'Orgs & Teams',
    'selflead':'Self-led',
  };

  var CALENDLY_URLS = {
    '1on1':  'https://calendly.com/placeholder-60',
    'group': 'https://calendly.com/placeholder-15',
    'orgs':  'https://calendly.com/placeholder-60',
  };

  // ── State
  var selectedOption = null;

  // ── Elements
  var step1       = document.getElementById('bfStep1');
  var step2       = document.getElementById('bfStep2');
  var step3       = document.getElementById('bfStep3');
  var optionBtns  = document.querySelectorAll('.bf-option');
  var backBtn     = document.getElementById('bfBack');
  var badge       = document.getElementById('bfSelectedBadge');
  var optionInput = document.getElementById('bfOptionInput');
  var form        = document.getElementById('bfForm');
  var submitBtn   = document.getElementById('bfSubmit');

  var advanceTimer = null;

  // ── Read URL param on load
  var params = new URLSearchParams(window.location.search);
  var paramOption = params.get('option');
  if (paramOption && OPTION_LABELS[paramOption]) {
    selectOption(paramOption, true);
  }

  // ── Option selection
  optionBtns.forEach(function (btn) {
    btn.addEventListener('click', function () {
      selectOption(btn.dataset.key, false);
    });
  });

  function selectOption(key, immediate) {
    selectedOption = key;
    optionBtns.forEach(function (btn) {
      var pressed = btn.dataset.key === key;
      btn.setAttribute('aria-pressed', pressed ? 'true' : 'false');
    });
    clearTimeout(advanceTimer);
    advanceTimer = setTimeout(function () {
      badge.textContent = OPTION_LABELS[selectedOption] || '';
      optionInput.value = selectedOption;
      document.documentElement.classList.remove('bf-has-param');
      showStep(step2);
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }, immediate ? 0 : 350);
  }

  // ── Back → Step 1
  backBtn.addEventListener('click', function () {
    showStep(step1);
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });

  // ── Form submission
  form.addEventListener('submit', function (e) {
    e.preventDefault();
    if (!validateForm()) return;

    submitBtn.disabled = true;
    submitBtn.classList.add('loading');

    var data = new URLSearchParams();
    data.append('form-name', 'begin');
    data.append('first-name', document.getElementById('bfFirstName').value.trim());
    data.append('email',      document.getElementById('bfEmail').value.trim());
    data.append('phone',      document.getElementById('bfPhone').value.trim());
    data.append('option',     selectedOption);

    fetch('/', {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: data.toString(),
    })
    .then(function () { advanceToStep3(); })
    .catch(function () {
      // On network error, still advance — don't block the user
      advanceToStep3();
    });
  });

  function validateForm() {
    var valid = true;

    var firstName = document.getElementById('bfFirstName');
    var firstNameErr = document.getElementById('bfFirstNameError');
    if (!firstName.value.trim()) {
      firstName.classList.add('bf-input--error');
      firstNameErr.classList.add('visible');
      valid = false;
    } else {
      firstName.classList.remove('bf-input--error');
      firstNameErr.classList.remove('visible');
    }

    var email = document.getElementById('bfEmail');
    var emailErr = document.getElementById('bfEmailError');
    var emailOk = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email.value.trim());
    if (!emailOk) {
      email.classList.add('bf-input--error');
      emailErr.classList.add('visible');
      valid = false;
    } else {
      email.classList.remove('bf-input--error');
      emailErr.classList.remove('visible');
    }

    return valid;
  }

  function advanceToStep3() {
    var calendlyMount  = document.getElementById('bfCalendlyMount');
    var calendlyWrap   = document.getElementById('bfCalendlyWrap');
    var selfleadWrap   = document.getElementById('bfSelfleadWrap');
    var calendlyEyebrow = document.getElementById('bfCalendlyEyebrow');

    if (selectedOption === 'selflead') {
      calendlyWrap.classList.add('bf-step--hidden');
      selfleadWrap.classList.remove('bf-step--hidden');
    } else {
      var url = CALENDLY_URLS[selectedOption];
      if (url && calendlyMount) {
        var primaryColor = '2956e0';
        var fullUrl = url + '?hide_gdpr_banner=1&primary_color=' + primaryColor + '&text_color=000000&background_color=ffffff';
        var widget = document.createElement('div');
        widget.className = 'calendly-inline-widget';
        widget.setAttribute('data-url', fullUrl);
        widget.style.minWidth = '280px';
        widget.style.height   = '700px';
        calendlyMount.appendChild(widget);

        if (typeof Calendly === 'undefined') {
          var s = document.createElement('script');
          s.src = 'https://assets.calendly.com/assets/external/widget.js';
          s.async = true;
          document.head.appendChild(s);
        } else {
          Calendly.initInlineWidgets();
        }
      }
      if (calendlyEyebrow) {
        calendlyEyebrow.textContent = OPTION_LABELS[selectedOption] || '';
      }
      selfleadWrap.classList.add('bf-step--hidden');
      calendlyWrap.classList.remove('bf-step--hidden');
    }

    showStep(step3);
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  function showStep(target) {
    [step1, step2, step3].forEach(function (s) {
      if (s === target) {
        s.classList.remove('bf-step--hidden');
        // Re-trigger animation
        s.style.animation = 'none';
        s.offsetHeight; // reflow
        s.style.animation = '';
      } else {
        s.classList.add('bf-step--hidden');
      }
    });
  }

  // ── Clear validation on input
  ['bfFirstName', 'bfEmail'].forEach(function (id) {
    var el = document.getElementById(id);
    if (el) {
      el.addEventListener('input', function () {
        el.classList.remove('bf-input--error');
        var errEl = document.getElementById(id + 'Error');
        if (errEl) errEl.classList.remove('visible');
      });
    }
  });

})();
</script>
