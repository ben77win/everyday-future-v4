---
import { practiceOptions } from '../data/options';
---
<section class="s2" id="practice">

  <!-- Header -->
  <div class="s2__header">
    <div class="s2__header-left">
      <span class="s2__headline-clip">
        <h2 class="s2__headline" id="s2Headline">Choose how you practice</h2>
      </span>
      <p class="s2__header-body">Coaching, resources, and community to develop ways of working that reduce resistance to the unknown, expand what's possible, and increase capacity for growth.</p>
    </div>
    <div class="s2__header-right">
      <div class="s2__tiers">
        <div class="s2__tier">
          <img src="/images/dunes.png" alt="Foundation" />
          <span class="s2__tier-label">Foundation</span>
        </div>
        <div class="s2__tier">
          <img src="/images/feather.png" alt="Calibration" />
          <span class="s2__tier-label">Calibration</span>
        </div>
        <div class="s2__tier">
          <img src="/images/lotus.png" alt="Expansion" />
          <span class="s2__tier-label">Expansion</span>
        </div>
      </div>
    </div>
  </div>

  <!-- 4 option cards -->
  <div class="s2__cards">
    {practiceOptions.map((opt) => (
      <a href={`/begin?option=${opt.key}`} class="s2__card">
        <span class="s2__card-arrow" aria-hidden="true">→</span>
        <span class="s2__card-label">{opt.label}</span>
        <span class="s2__card-desc">{opt.desc}</span>
      </a>
    ))}
  </div>

</section>
