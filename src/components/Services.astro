---
---
<section class="s2" id="practice">

  <!-- Header -->
  <div class="s2__header">
    <div class="s2__header-left">
      <span class="s2__headline-clip">
        <h2 class="s2__headline" id="s2Headline">Choose your way to practice</h2>
      </span>
    </div>
    <div class="s2__header-right" style="position:relative;">
      <p class="s2__subhead">A new way needs practice to make progress. Begin working with the future you want, now.</p>
      <img src="/marks/Vector-4.svg" style="position:absolute;top:-18px;right:-24px;width:155px;opacity:0.32;pointer-events:none;transform:rotate(-4deg);" alt="" aria-hidden="true" />
    </div>
  </div>

  <!-- 4 coaching option rows -->
  <div class="s2__options">

    <a href="/begin?option=1on1" class="s2__option">
      <span class="s2__option-title">1:1 Coaching</span>
      <span class="s2__option-desc">Dedicated practice to work on what matters for you with a coach</span>
      <span class="s2__option-arrow">→</span>
    </a>

    <a href="/begin?option=orgs" class="s2__option">
      <span class="s2__option-title">Orgs &amp; Teams</span>
      <span class="s2__option-desc">Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor</span>
      <span class="s2__option-arrow">→</span>
    </a>

    <a href="/begin?option=group" class="s2__option">
      <span class="s2__option-title">Group Coaching</span>
      <span class="s2__option-desc">Shared practice in community with structure, support, and a coach</span>
      <span class="s2__option-arrow">→</span>
    </a>

    <a href="/begin?option=selflead" class="s2__option">
      <span class="s2__option-title">Self-led</span>
      <span class="s2__option-desc">Practice on your own with structure and guidance</span>
      <span class="s2__option-arrow">→</span>
    </a>

  </div>

  <!-- Free discovery call — parallax scatter strip -->
  <div class="s2__free" id="s2Free">

    <!-- Text content -->
    <div class="s2__free-content" style="position:relative;">
      <div class="s2__free-title">Free discovery call</div>
      <img src="/marks/Vector-6.svg" style="position:absolute;top:28px;left:200px;width:200px;opacity:0.42;pointer-events:none;transform:rotate(3deg);" alt="" aria-hidden="true" />
      <p class="s2__free-desc">Try practice before you commit</p>
      <a href="/begin" class="s2__free-cta">Begin</a>
    </div>

    <!-- Scattered images with parallax data attributes -->
    <img src="/images/feather.png"       class="s2__free-img s2__free-img--a" data-parallax="0.20" alt="" aria-hidden="true" />
    <img src="/images/lotus.png"         class="s2__free-img s2__free-img--b" data-parallax="-0.28" alt="" aria-hidden="true" />
    <img src="/images/dunes.png"         class="s2__free-img s2__free-img--c" data-parallax="0.14" alt="" aria-hidden="true" />
    <img src="/images/window-sunset.png" class="s2__free-img s2__free-img--d" data-parallax="-0.22" alt="" aria-hidden="true" />

  </div>

</section>
