---
import '../styles/global.css';
---
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Every Day Future</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@300;400&family=Inter:wght@200&display=swap" rel="stylesheet" />
</head>
<body>

<slot />

<script>
  // ── Hero image rotation — cycles sequentially on each reload
  (function() {
    var bg = document.querySelector('.hero__bg');
    if (!bg) return;
    var images = [
      { src: '/images/hero-rose.png',    pos: '50% 30%' },
      { src: '/images/hero-red-sun.jpg', pos: '50% 40%' },
      { src: '/images/feather.png',      pos: '50% 50%' },
      { src: '/images/lotus.png',        pos: '50% 60%' }
    ];
    var idx  = (parseInt(localStorage.getItem('edf_hero') || '0') + 1) % images.length;
    localStorage.setItem('edf_hero', idx);
    bg.style.backgroundImage    = 'url(' + images[idx].src + ')';
    bg.style.backgroundPosition = images[idx].pos;
  })();

  // ── Hero wordmark intro — nav wordmark scales from large/centered down into nav on scroll
  (function() {
    var wordmark = document.querySelector('.nav__wordmark');
    var heroCopy = document.querySelector('.hero__copy');
    if (!wordmark || !document.querySelector('.hero__bg')) return;

    document.body.classList.add('hero-wordmark-active');

    // Measure natural (rest) position in the nav at scale=1
    var rect  = wordmark.getBoundingClientRect();
    var elCX  = rect.left + rect.width  / 2;
    var elCY  = rect.top  + rect.height / 2;
    var vpCX  = window.innerWidth  / 2;
    var vpCY  = window.innerHeight / 2;

    // Scale so wordmark fills ~62% of viewport width
    var SCALE = Math.min((window.innerWidth * 0.62) / rect.width, 9);

    // Translate needed so element center lands on viewport center (applied AFTER scale)
    var TX0 = vpCX - elCX;
    var TY0 = vpCY - elCY;

    var THRESHOLD = window.innerHeight * 0.65;

    function clamp(v, lo, hi) { return v < lo ? lo : v > hi ? hi : v; }

    function tick() {
      var p = clamp(window.scrollY / THRESHOLD, 0, 1);

      var scale = SCALE + (1 - SCALE) * p;
      var tx    = TX0  * (1 - p);
      var ty    = TY0  * (1 - p);

      wordmark.style.transform = 'translate(' + tx + 'px,' + ty + 'px) scale(' + scale + ')';

      if (heroCopy) {
        var cp = clamp((p - 0.3) / 0.55, 0, 1);
        heroCopy.style.opacity   = cp;
        heroCopy.style.transform = 'translateY(' + (20 * (1 - cp)) + 'px)';
      }
    }

    window.addEventListener('scroll', tick, { passive: true });
    tick();
  })();

  // ── Nav + floating CTA: toggle after hero exits
  var nav      = document.getElementById('nav');
  var hero     = document.getElementById('hero');
  var floatCta = document.getElementById('floatCta');

  if (hero && nav && floatCta) {
    new IntersectionObserver(function(entries) {
      var heroVisible = entries[0].isIntersecting;
      nav.classList.toggle('scrolled', !heroVisible);
      floatCta.classList.toggle('visible', !heroVisible);
    }, { threshold: 0.15 }).observe(hero);
  }

  // ── Float CTA: invert when footer is visible
  var siteFooter = document.querySelector('.site-footer');
  if (floatCta && siteFooter) {
    new IntersectionObserver(function(entries) {
      floatCta.classList.toggle('over-footer', entries[0].isIntersecting);
    }, { threshold: 0 }).observe(siteFooter);
  }

  // ── S2 headline clip reveal: fires once when S2 enters view
  var s2Headline = document.getElementById('s2Headline');
  var s2Section  = document.getElementById('practice');
  if (s2Headline && s2Section) {
    new IntersectionObserver(function(entries, obs) {
      if (entries[0].isIntersecting) {
        s2Headline.classList.add('revealed');
        obs.disconnect();
      }
    }, { threshold: 0.3 }).observe(s2Section);
  }

  // ── S2 option rows + free strip + S3 quotes: staggered scroll reveal
  var revealEls = document.querySelectorAll('.s2__option, .s2__free, .s3__quote, .s4__body, .s4__tags, .s5__left, .s5__item, .s6__photos, .s6__bio, .s7__item');
  if (revealEls.length) {
    var rowObs = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          var el = entry.target;
          var delay = el.dataset.delay || 0;
          setTimeout(function() { el.classList.add('revealed'); }, delay);
          rowObs.unobserve(el);
        }
      });
    }, { threshold: 0.15 });

    revealEls.forEach(function(el, i) {
      el.dataset.delay = i * 110;
      rowObs.observe(el);
    });
  }

  // ── Parallax: S2 scatter + S3 quote images
  var parallaxImgs = document.querySelectorAll('[data-parallax]');
  if (parallaxImgs.length) {
    function updateParallax() {
      parallaxImgs.forEach(function(img) {
        var parent = img.closest('.s2__free, .s3__quote, .s6__photos');
        if (!parent) return;
        var rect = parent.getBoundingClientRect();
        var centerOffset = (rect.top + rect.height / 2) - window.innerHeight / 2;
        var speed = parseFloat(img.dataset.parallax);
        img.style.transform = 'translateY(' + (centerOffset * speed) + 'px)';
      });
    }
    window.addEventListener('scroll', updateParallax, { passive: true });
    updateParallax();
  }

  // ── FAQ accordion
  document.querySelectorAll('.s7__trigger').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var item = btn.closest('.s7__item');
      var isOpen = item.classList.contains('open');
      document.querySelectorAll('.s7__item.open').forEach(function(el) {
        el.classList.remove('open');
        el.querySelector('.s7__trigger').setAttribute('aria-expanded', 'false');
      });
      if (!isOpen) {
        item.classList.add('open');
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });
</script>

</body>
</html>
