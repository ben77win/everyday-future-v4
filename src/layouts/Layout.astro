---
import '../styles/global.css';
---
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Every Day Future</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@300;400&family=Inter:wght@200&display=swap" rel="stylesheet" />
</head>
<body>

<slot />

<script>
  // ── Hero image rotation — cycles sequentially on each reload
  (function() {
    var bg = document.querySelector('.hero__bg');
    if (!bg) return;
    var images = [
      { src: '/images/hero-rose.png',    pos: '50% 30%' },
      { src: '/images/hero-red-sun.jpg', pos: '50% 40%' },
      { src: '/images/feather.png',      pos: '50% 50%' },
      { src: '/images/lotus.png',        pos: '50% 60%' }
    ];
    var idx  = (parseInt(localStorage.getItem('edf_hero') || '0') + 1) % images.length;
    localStorage.setItem('edf_hero', idx);
    bg.style.backgroundImage    = 'url(' + images[idx].src + ')';
    bg.style.backgroundPosition = images[idx].pos;
  })();

  // ── Hero wordmark intro — renders large (crisp), scales down into nav on scroll
  (function() {
    var wordmark = document.querySelector('.nav__wordmark');
    var heroCopy = document.querySelector('.hero__copy');
    if (!wordmark || !document.querySelector('.hero__bg')) return;

    // 1. Measure original nav-size width before any changes (used for NAV_SCALE)
    var r0    = wordmark.getBoundingClientRect();

    // 2. Add active class (CSS sets position:absolute; left:50%; top:50% on wordmark)
    //    then set large font-size for crisp rendering
    var navEl = document.getElementById('nav');
    document.body.classList.add('hero-wordmark-active');
    wordmark.style.fontSize = Math.min(window.innerWidth * 0.085, 85) + 'px';
    wordmark.offsetWidth; // force reflow

    // 3. Measure hero dimensions and nav height after class has settled
    var r1    = wordmark.getBoundingClientRect();
    var heroW = r1.width;
    var heroH = r1.height;
    var navH  = navEl.getBoundingClientRect().height; // nav height after class (padding-only)

    // 4. NAV_SCALE: shrinks display-size back to nav-size (always < 1 → crisp scaling)
    var NAV_SCALE = r0.width / heroW;

    // With CSS left:50%; top:50%, the element's top-left sits at (vp_width/2, navH/2).
    // Element natural center = (vp_width/2 + heroW/2,  navH/2 + heroH/2).
    //
    // TX = -heroW/2  → centers element horizontally at any viewport width (pure CSS %)
    //
    // TYf = -heroH/2 → at p=1: center Y = navH/2 + heroH/2 - heroH/2 = navH/2  (nav center ✓)
    // TY0            → at p=0: center Y = 40% of viewport height
    var TX  = -heroW / 2;
    var TYf = -heroH / 2;
    var TY0 = (window.innerHeight * 0.40) - (navH / 2 + heroH / 2);

    var THRESHOLD = window.innerHeight * 0.48;
    function clamp(v, lo, hi) { return v < lo ? lo : v > hi ? hi : v; }

    function tick() {
      var p  = clamp(window.scrollY / THRESHOLD, 0, 1);
      var pe = p * p; // ease-in² — snaps to nav before overlapping copy

      var scale = 1 + (NAV_SCALE - 1) * pe;
      var ty    = TY0 + (TYf - TY0) * pe;
      wordmark.style.transform = 'translate(' + TX + 'px,' + ty + 'px) scale(' + scale + ')';

      if (heroCopy) {
        var cp = clamp((p - 0.55) / 0.35, 0, 1);
        heroCopy.style.opacity   = cp;
        heroCopy.style.transform = 'translateY(' + (20 * (1 - cp)) + 'px)';
      }
    }

    window.addEventListener('scroll', tick, { passive: true });
    tick();
  })();

  // ── Nav + floating CTA: toggle after hero exits
  var nav      = document.getElementById('nav');
  var hero     = document.getElementById('hero');
  var floatCta = document.getElementById('floatCta');

  if (hero && nav && floatCta) {
    new IntersectionObserver(function(entries) {
      var heroVisible = entries[0].isIntersecting;
      nav.classList.toggle('scrolled', !heroVisible);
      floatCta.classList.toggle('visible', !heroVisible);
    }, { threshold: 0.15 }).observe(hero);
  }

  // ── Float CTA: invert when footer is visible
  var siteFooter = document.querySelector('.site-footer');
  if (floatCta && siteFooter) {
    new IntersectionObserver(function(entries) {
      floatCta.classList.toggle('over-footer', entries[0].isIntersecting);
    }, { threshold: 0 }).observe(siteFooter);
  }

  // ── S2 headline clip reveal: fires once when S2 enters view
  var s2Headline = document.getElementById('s2Headline');
  var s2Section  = document.getElementById('practice');
  if (s2Headline && s2Section) {
    new IntersectionObserver(function(entries, obs) {
      if (entries[0].isIntersecting) {
        s2Headline.classList.add('revealed');
        obs.disconnect();
      }
    }, { threshold: 0.3 }).observe(s2Section);
  }

  // ── S2 option rows + S3 + other sections: staggered scroll reveal
  var revealEls = document.querySelectorAll('.s2__option, .s3, .s4__body, .s4__tags, .s5__left, .s5__body, .s6__photos, .s6__bio, .s7__item');
  if (revealEls.length) {
    var rowObs = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          var el = entry.target;
          var delay = el.dataset.delay || 0;
          setTimeout(function() { el.classList.add('revealed'); }, delay);
          rowObs.unobserve(el);
        }
      });
    }, { threshold: 0.15 });

    revealEls.forEach(function(el, i) {
      el.dataset.delay = i * 110;
      rowObs.observe(el);
    });
  }

  // ── Parallax: S2 scatter + S3 quote images
  var parallaxImgs = document.querySelectorAll('[data-parallax]');
  if (parallaxImgs.length) {
    function updateParallax() {
      parallaxImgs.forEach(function(img) {
        var parent = img.closest('.s6__photos');
        if (!parent) return;
        var rect = parent.getBoundingClientRect();
        var centerOffset = (rect.top + rect.height / 2) - window.innerHeight / 2;
        var speed = parseFloat(img.dataset.parallax);
        img.style.transform = 'translateY(' + (centerOffset * speed) + 'px)';
      });
    }
    window.addEventListener('scroll', updateParallax, { passive: true });
    updateParallax();
  }

  // ── S3 rail — mouse drag-to-scroll (touch is native)
  (function () {
    var rail = document.getElementById('s3Rail');
    if (!rail) return;
    var isDown = false, startX = 0, startScroll = 0;
    rail.addEventListener('pointerdown', function (e) {
      if (e.pointerType !== 'mouse') return;
      isDown = true;
      startX = e.pageX;
      startScroll = rail.scrollLeft;
      rail.classList.add('is-dragging');
      try { rail.setPointerCapture(e.pointerId); } catch (_) {}
    });
    rail.addEventListener('pointermove', function (e) {
      if (!isDown) return;
      var dx = e.pageX - startX;
      rail.scrollLeft = startScroll - dx;
    });
    function endDrag() {
      if (!isDown) return;
      isDown = false;
      rail.classList.remove('is-dragging');
      // Re-snap to nearest card
      var cards = rail.querySelectorAll('.s3__card');
      if (!cards.length) return;
      var cardW = cards[0].getBoundingClientRect().width;
      var nearest = Math.round(rail.scrollLeft / cardW) * cardW;
      rail.scrollTo({ left: nearest, behavior: 'smooth' });
    }
    rail.addEventListener('pointerup', endDrag);
    rail.addEventListener('pointercancel', endDrag);
    rail.addEventListener('pointerleave', endDrag);
  })();

  // ── FAQ accordion
  document.querySelectorAll('.s7__trigger').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var item = btn.closest('.s7__item');
      var isOpen = item.classList.contains('open');
      document.querySelectorAll('.s7__item.open').forEach(function(el) {
        el.classList.remove('open');
        el.querySelector('.s7__trigger').setAttribute('aria-expanded', 'false');
      });
      if (!isOpen) {
        item.classList.add('open');
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });
</script>

</body>
</html>
