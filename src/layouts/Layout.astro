---
import '../styles/global.css';
---
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Every Day Future</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@300;400&family=Inter:wght@200&display=swap" rel="stylesheet" />
</head>
<body ontouchstart="">

<slot />

<script>
  // ── Hero image rotation — cycles sequentially on each reload
  (function() {
    var bg = document.querySelector('.hero__bg');
    if (!bg) return;
    var images = [
      { src: '/images/horizon.png',       pos: '50% 50%' },
      { src: '/images/rose.png',          pos: '50% 35%' },
      { src: '/images/window-sunset.png', pos: '50% 60%' },
      { src: '/images/hero-red-sun.jpg',  pos: '50% 40%' }
    ];
    var idx  = (parseInt(localStorage.getItem('edf_hero') || '0') + 1) % images.length;
    localStorage.setItem('edf_hero', idx);
    bg.style.backgroundImage    = 'url(' + images[idx].src + ')';
    bg.style.backgroundPosition = images[idx].pos;
  })();

  // ── Nav + floating CTA: toggle after hero exits
  var nav      = document.getElementById('nav');
  var hero     = document.getElementById('hero');
  var floatCta = document.getElementById('floatCta');

  if (hero && nav && floatCta) {
    new IntersectionObserver(function(entries) {
      var heroVisible = entries[0].isIntersecting;
      nav.classList.toggle('scrolled', !heroVisible);
      floatCta.classList.toggle('visible', !heroVisible);
    }, { threshold: 0.15 }).observe(hero);
  }

  // ── S2 headline clip reveal: fires once when S2 enters view
  var s2Headline = document.getElementById('s2Headline');
  var s2Section  = document.getElementById('practice');
  if (s2Headline && s2Section) {
    new IntersectionObserver(function(entries, obs) {
      if (entries[0].isIntersecting) {
        s2Headline.classList.add('revealed');
        obs.disconnect();
      }
    }, { threshold: 0.3 }).observe(s2Section);
  }

  // ── S2 cards + S3 + other sections: staggered scroll reveal
  var revealEls = document.querySelectorAll('.s2__card, .s3, .s4__body, .s4__tags, .s5__left, .s5__body, .s6__photos, .s6__bio, .s7__item');
  if (revealEls.length) {
    var rowObs = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          var el = entry.target;
          var delay = el.dataset.delay || 0;
          setTimeout(function() { el.classList.add('revealed'); }, delay);
          rowObs.unobserve(el);
        }
      });
    }, { threshold: 0.15 });

    revealEls.forEach(function(el, i) {
      el.dataset.delay = i * 110;
      rowObs.observe(el);
    });
  }

  // ── S3 rail auto-advance every 4s, pauses on hover/touch
  (function () {
    var rail = document.getElementById('s3Rail');
    if (!rail) return;
    var paused = false;
    rail.addEventListener('pointerdown', function() { paused = true; });
    rail.addEventListener('mouseenter',  function() { paused = true; });
    rail.addEventListener('mouseleave',  function() { paused = false; });
    setInterval(function() {
      if (paused) return;
      var cards = rail.querySelectorAll('.s3__card');
      if (!cards.length) return;
      var w = cards[0].getBoundingClientRect().width + 4;
      var max = rail.scrollWidth - rail.clientWidth;
      var next = rail.scrollLeft + w;
      if (next > max - 8) next = 0;
      rail.scrollTo({ left: next, behavior: 'smooth' });
    }, 4000);
  })();

  // ── S3 rail — mouse drag-to-scroll (touch is native)
  (function () {
    var rail = document.getElementById('s3Rail');
    if (!rail) return;
    var isDown = false, startX = 0, startScroll = 0;
    rail.addEventListener('pointerdown', function (e) {
      if (e.pointerType !== 'mouse') return;
      isDown = true;
      startX = e.pageX;
      startScroll = rail.scrollLeft;
      rail.classList.add('is-dragging');
      try { rail.setPointerCapture(e.pointerId); } catch (_) {}
    });
    rail.addEventListener('pointermove', function (e) {
      if (!isDown) return;
      var dx = e.pageX - startX;
      rail.scrollLeft = startScroll - dx;
    });
    function endDrag() {
      if (!isDown) return;
      isDown = false;
      rail.classList.remove('is-dragging');
      // Re-snap to nearest card
      var cards = rail.querySelectorAll('.s3__card');
      if (!cards.length) return;
      var cardW = cards[0].getBoundingClientRect().width;
      var nearest = Math.round(rail.scrollLeft / cardW) * cardW;
      rail.scrollTo({ left: nearest, behavior: 'smooth' });
    }
    rail.addEventListener('pointerup', endDrag);
    rail.addEventListener('pointercancel', endDrag);
    rail.addEventListener('pointerleave', endDrag);
  })();

  // ── FAQ accordion
  document.querySelectorAll('.s7__trigger').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var item = btn.closest('.s7__item');
      var isOpen = item.classList.contains('open');
      document.querySelectorAll('.s7__item.open').forEach(function(el) {
        el.classList.remove('open');
        el.querySelector('.s7__trigger').setAttribute('aria-expanded', 'false');
      });
      if (!isOpen) {
        item.classList.add('open');
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });
</script>

</body>
</html>
