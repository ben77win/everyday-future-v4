---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import CTABar from '../components/CTABar.astro';
import Services from '../components/Services.astro';
import Testimonials from '../components/Testimonials.astro';
import About from '../components/About.astro';
import Waymaker from '../components/Waymaker.astro';
import TaylorBio from '../components/TaylorBio.astro';
import FAQ from '../components/FAQ.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import BeginFlow from '../components/BeginFlow.astro';
---
<Layout>
  <Nav />
  <Hero />
  <CTABar />
  <Services />
  <Testimonials />
  <About />
  <Waymaker />
  <TaylorBio />
  <FAQ />
  <Contact />
  <Footer />

  <!-- ── Begin drawer ── -->
  <div class="begin-drawer" id="beginDrawer" role="dialog" aria-modal="true" aria-label="Begin your practice" aria-hidden="true">
    <div class="begin-drawer__bar">
      <button class="begin-drawer__close" id="beginDrawerClose" type="button" aria-label="Close">
        <span class="begin-drawer__close-arrow" aria-hidden="true">←</span>
        <span class="t-cta">Back</span>
      </button>
    </div>
    <main class="begin-page begin-page--drawer">
      <BeginFlow />
    </main>
  </div>
  <div class="begin-drawer__scrim" id="beginDrawerScrim"></div>
</Layout>

<style is:global>
  /* Hide step 1 before paint when a valid option param is present */
  html.bf-has-param #bfStep1 { display: none !important; }
  html.bf-has-param #bfStep2 { display: flex !important; }
</style>

<style>
/* ── Drawer shell */
.begin-drawer {
  position: fixed;
  inset: 0;
  z-index: 600;
  background: var(--paper-cream, #fffcd1);
  transform: translateY(100%);
  transition: transform 0.55s cubic-bezier(0.16, 1, 0.3, 1);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}
.begin-drawer.open {
  transform: translateY(0);
}

/* ── Top bar with close */
.begin-drawer__bar {
  position: sticky;
  top: 0;
  z-index: 10;
  height: 60px;
  display: flex;
  align-items: center;
  padding: 0 var(--gutter, 60px);
  background: transparent;
  border-bottom: 0.5px solid rgba(0,0,0,0.10);
  flex-shrink: 0;
}

.begin-drawer__close {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 0;
  color: rgba(0,0,0,0.40);
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: 0.140em;
  text-transform: uppercase;
  transition: color 0.2s ease;
}
.begin-drawer__close:hover { color: var(--ink, #000); }
.begin-drawer__close:focus { outline: none; }
.begin-drawer__close:focus-visible { outline: 1.5px solid rgba(0,0,0,0.30); outline-offset: 4px; border-radius: 2px; }
.begin-drawer__close-arrow { font-size: 14px; }

/* ── Scrollable content */
.begin-page--drawer {
  flex: 1;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  padding-top: 0 !important;
  background: transparent;
  min-height: 0;
}

/* ── Scrim */
.begin-drawer__scrim {
  position: fixed;
  inset: 0;
  z-index: 599;
  background: rgba(0,0,0,0.35);
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.4s ease;
}
.begin-drawer__scrim.visible {
  opacity: 1;
  pointer-events: auto;
}

@media (max-width: 640px) {
  .begin-drawer__bar { padding: 0 22px; }
}
</style>

<script is:inline>
(function () {
  var drawer     = document.getElementById('beginDrawer');
  var scrim      = document.getElementById('beginDrawerScrim');
  var closeBtn   = document.getElementById('beginDrawerClose');
  var scrollArea = drawer ? drawer.querySelector('.begin-page--drawer') : null;

  if (!drawer || !scrim || !closeBtn || !scrollArea) return;

  var _origScrollTo = window.scrollTo.bind(window);

  function openDrawer() {
    drawer.classList.add('open');
    drawer.setAttribute('aria-hidden', 'false');
    scrim.classList.add('visible');
    document.body.style.overflow = 'hidden';
    history.pushState({ beginDrawer: true }, '', '/begin');

    // Patch window.scrollTo so BeginFlow's step transitions scroll the drawer
    window.scrollTo = function (opts) {
      if (opts && typeof opts === 'object' && opts.top === 0) {
        scrollArea.scrollTo({ top: 0, behavior: opts.behavior || 'smooth' });
      } else {
        _origScrollTo.apply(window, arguments);
      }
    };

    // Focus first interactive element
    var firstBtn = drawer.querySelector('button, input, a');
    if (firstBtn) setTimeout(function () { firstBtn.focus(); }, 550);
  }

  function closeDrawer() {
    drawer.classList.remove('open');
    drawer.setAttribute('aria-hidden', 'true');
    scrim.classList.remove('visible');
    document.body.style.overflow = '';
    window.scrollTo = _origScrollTo;
    if (location.pathname === '/begin') {
      history.replaceState(null, '', '/');
    }
  }

  window.__openBeginDrawer = openDrawer;

  closeBtn.addEventListener('click', closeDrawer);
  scrim.addEventListener('click', closeDrawer);

  window.addEventListener('popstate', function (e) {
    if (drawer.classList.contains('open')) {
      closeDrawer();
    }
  });

  // Keyboard: Escape closes
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && drawer.classList.contains('open')) {
      closeDrawer();
    }
  });
})();
</script>
