---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import BeginFlow from '../components/BeginFlow.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <Nav />

  <main class="begin-page">
    <BeginFlow />
  </main>

  <Footer />
</Layout>

<style is:global>
  .page-begin .nav__wordmark,
  .page-begin .nav__link {
    color: var(--ink);
  }

  /* Hide step 1 before paint when a valid option param is present */
  html.bf-has-param #bfStep1 { display: none !important; }
  html.bf-has-param #bfStep2 { display: flex !important; }
</style>

<style>
.begin-page {
  padding-top: 68px;
  background: var(--paper);
  min-height: 100vh;
}

@media (max-width: 640px) {
  .begin-page { padding-top: 60px; }
}
</style>

<script is:inline>
  document.documentElement.classList.add('page-begin');
  (function() {
    var opt = new URLSearchParams(window.location.search).get('option');
    if (opt && ['1on1','group','orgs','selflead'].indexOf(opt) !== -1) {
      document.documentElement.classList.add('bf-has-param');
    }
  })();
</script>
